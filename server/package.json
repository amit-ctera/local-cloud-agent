{
  "name": "local-cloud-agent",
  "version": "1.0.0",
  "description": "Secure desktop app for remote Cursor CLI access via ngrok",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron .",
    "build:renderer": "npx vite build --config renderer/vite.config.mjs renderer",
    "build": "npm run build:renderer && electron-builder --win --publish never",
    "publish": "npm run build:renderer && electron-builder --win --publish always",
    "start": "electron ."
  },
  "engines": {
    "node": ">=18"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "better-sqlite3": "^11.7.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "@ngrok/ngrok": "^1.4.1",
    "uuid": "^11.1.0",
    "electron-store": "^8.2.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.localcloudagent.app",
    "productName": "Local Cloud Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "renderer/dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "amit-ctera",
      "repo": "local-cloud-agent"
    }
  }
}
